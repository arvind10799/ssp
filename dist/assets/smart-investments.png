    document.querySelectorAll('.multi-pdf-button').forEach(function(button) {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            
            // First PDF
            const link1 = document.createElement('a');
            link1.href = 'https://sspgroup.org.in/wp-content/uploads/2025/11/Type-1-East-Plan_.pdf';
            link1.download = 'Type-1-East-Plan.pdf';
            link1.click();
            
            // Second PDF (download after 500ms delay)
            setTimeout(function() {
                const link2 = document.createElement('a');
                link2.href = 'https://sspgroup.org.in/wp-content/uploads/2025/11/Type-1-West-Plan_.pdf';
                link2.download = 'Type-1-West-Plan.pdf';
                link2.click();
            }, 500);
        });
    });
});

