<script>
// FAQ toggle button
jQuery(document).ready(function($) {
    $('.custom-faq-question').click(function() {
        const faqItem = $(this).closest('.custom-faq-item');
        const answer = faqItem.find('.custom-faq-answer');
        
        // Toggle only the clicked item
        answer.stop().slideToggle(300, function() {
            faqItem.toggleClass('active', answer.is(':visible'));
        });
        
        // Close other items if needed (remove this section if you want multiple open)
        $('.custom-faq-item').not(faqItem).removeClass('active').find('.custom-faq-answer').slideUp(300);
    });
});
</script>
<script>
jQuery(document).ready(function($) {
    // Hide all detail contents initially
    $('.category-details').hide();

    // Category button click handler
    $('.map-category').on('click', function(e) {
        e.preventDefault();
        const $button = $(this);
        const $details = $button.siblings('.category-details');
        
        // Toggle active class on button
        $button.toggleClass('active');
        
        // Toggle the details container
        $details.slideToggle(300);
        
        // Toggle the toggle icon
        $button.find('.toggle-icon').text($button.hasClass('active') ? '' : '');
        
        // Close other open details
        $('.category-details').not($details).slideUp(300);
        $('.map-category').not($button).removeClass('active').find('.toggle-icon').text('');
    });
});
</script>

<script>
jQuery(document).ready(function($) {
  // Use MutationObserver for dynamic forms
  const observer = new MutationObserver(() => {
    const checkbox = $('#form-field-field_78b9c83-0');
    if (checkbox.length) {
      checkbox.prop('checked', true);
      observer.disconnect();
    }
  });
  observer.observe(document.body, { childList: true, subtree: true });
});
</script>


<script>
document.addEventListener('DOMContentLoaded', function() {
  // Target form by ID
  const form = document.querySelector('#CareerForm');
  
  if (form) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();

      // Get form data
      const formData = {
        fname: form.querySelector('[name="fname"]').value,
        lname: form.querySelector('[name="lname"]').value,
        email: form.querySelector('[name="email"]').value,
        phone: form.querySelector('[name="phone"]').value,
        position: form.querySelector('[name="position"]').value,
        message: form.querySelector('[name="message"]').value,
        resume: form.querySelector('[name="resume"]').value
      };

      try {
        const response = await fetch('YOUR_GOOGLE_SCRIPT_URL', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formData)
        });
        
        if (response.ok) {
          alert('Submitted successfully!');
          form.reset(); // Clear form
        } else {
          throw new Error('Server error');
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Submission failed. Check console.');
      }
    });
  }
});
</script>
<script>
(function(){
    var SCALE_X = 0.96;
    var BUFFER  = 20;

    function fitAllLocationTexts(){
        /* querySelectorAll targets ALL bg-location-text headings on the page */
        var elements = document.querySelectorAll('.bg-location-text .elementor-heading-title');
        var wraps    = document.querySelectorAll('.bg-location-text');

        elements.forEach(function(el, i){
            var wrap = wraps[i];
            if(!el || !wrap) return;

            /* Reset inline font-size */
            el.style.fontSize = '20vw';

            requestAnimationFrame(function(){
                var containerW = wrap.offsetWidth - BUFFER;
                var textW      = el.scrollWidth;
                var visualW    = textW * SCALE_X;
                var currentFS  = parseFloat(window.getComputedStyle(el).fontSize);
                var newFS      = currentFS * (containerW / visualW);
                el.style.fontSize = newFS + 'px';
            });
        });
    }

    window.addEventListener('load',   fitAllLocationTexts);
    window.addEventListener('resize', fitAllLocationTexts);
    window.addEventListener('elementor/frontend/init', fitAllLocationTexts);
})();
</script>


	</body>
</html>
