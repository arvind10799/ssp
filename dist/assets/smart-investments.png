/* ================================================
   CLS MASTER FIX — SSP Group Project Pages
   Targets: Popup shift, reCAPTCHA, carousel, mobile
   Goal: Desktop < 0.10 | Mobile < 0.10
================================================ */

/* --- FIX 1: SCROLLBAR SHIFT PREVENTION --- */
/* Reserve scrollbar width so page doesn't shift */
html {
    scrollbar-gutter: stable;
    overflow-x: clip !important;
}

/* When popup opens — compensate scrollbar disappearing */
body.elementor-popup-open {
    overflow: hidden !important;
    padding-right: var(--scrollbar-width, 15px) !important;
}

/* Sticky header compensation when popup opens */
body.elementor-popup-open .elementor-sticky,
body.elementor-popup-open header {
    padding-right: var(--scrollbar-width, 15px) !important;
}

/* --- FIX 2: POPUP COMPOSITOR LAYER --- */
/* Force popup onto GPU layer — no layout reflow */
.elementor-popup-modal {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    z-index: 9999 !important;
    contain: strict;
}

.dialog-widget-content {
    will-change: opacity;
    transform: translateZ(0);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
}

.dialog-lightbox-widget-content {
    position: fixed !important;
    contain: layout style;
}

/* --- FIX 3: RECAPTCHA BADGE CLS --- */
/* Prevent reCAPTCHA from causing reflow */
.grecaptcha-badge {
    position: fixed !important;
    bottom: 14px !important;
    right: 14px !important;
    will-change: transform;
    transform: translateZ(0);
    z-index: 9999;
    /* Hide by default — shows only when needed */
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
}

/* Show reCAPTCHA only when form is being interacted with */
.elementor-popup-modal .grecaptcha-badge,
form:focus-within ~ .grecaptcha-badge,
.elementor-form:focus-within .grecaptcha-badge {
    opacity: 1;
    pointer-events: auto;
}

/* Fix reCAPTCHA iframe CLS */
.elementor-field-type-recaptcha_v3 {
    height: 0 !important;
    overflow: hidden !important;
    position: absolute !important;
    visibility: hidden !important;
}

/* --- FIX 4: WCF ANIMATION CLASSES ON POPUP --- */
/* Prevent WCF starter animation recalculation */
.elementor-location-popup .wcf-animate,
.elementor-location-popup .wcf-starter-animations-none {
    animation: none !important;
    transition: none !important;
    transform: none !important;
    opacity: 1 !important;
    visibility: visible !important;
}

.elementor-image-carousel-wrapper .swiper,
.elementor-image-carousel-wrapper .swiper-wrapper {
    min-height: 400px;
}

.elementor-image-carousel-wrapper .swiper-slide img {
    width: 100% !important;
    height: auto !important;
    aspect-ratio: 16 / 9;
    object-fit: contain;
    display: block;
}



/* --- FIX 6: GLOBAL IMAGE STABILITY --- */
img:not([width]):not([height]) {
    aspect-ratio: auto;
}

.elementor-widget-image img {
    display: block;
    width: 100%;
    height: auto;
}

/* --- FIX 7: FAQ STABILITY --- */
.custom-faq-container {
    contain: layout;
}

.custom-faq-answer {
    overflow: hidden;
}

/* --- FIX 8: STICKY HEADER NO REFLOW --- */
.elementor-sticky--effects {
    transition: background-color 0.3s ease,
                box-shadow 0.3s ease !important;
    will-change: background-color;
}

/* ================================================
   MOBILE SPECIFIC
================================================ */
@media (max-width: 767px) {

    .elementor-image-carousel-wrapper,
    .elementor-image-carousel-wrapper .swiper,
    .elementor-image-carousel-wrapper .swiper-wrapper {
        min-height: 220px;
    }

    /* Popup full screen on mobile */
    .elementor-popup-modal .dialog-widget-content {
        width: 100% !important;
        max-height: 90vh !important;
        overflow-y: auto !important;
    }

    /* reCAPTCHA mobile */
    .grecaptcha-badge {
        bottom: 70px !important;
        right: 10px !important;
    }
}



/* Center this specific hero image */
.elementor-widget-image[data-widget_type="image.default"] img {
    margin-left: auto;
    margin-right: auto;
    display: block;
}



.elementor-element-b267c50 .elementor-image-carousel-wrapper,
.elementor-element-b267c50 .elementor-image-carousel-wrapper .swiper,
.elementor-element-b267c50 .elementor-image-carousel-wrapper .swiper-wrapper {
    min-height: 0 !important;
}
/* === Fix extra bottom space under Clubhouse Gallery on mobile === */
@media (max-width: 767px) {
    .ssp-hero-thumb-gallery {
        margin-bottom: 0 !important;
    }
    
    .elementor-widget-shortcode:has(.ssp-hero-thumb-gallery) {
        margin-bottom: 0 !important;
        padding-bottom: 0 !important;
    }
    
    .elementor-widget-shortcode:has(.ssp-hero-thumb-gallery) .elementor-widget-container {
        margin-bottom: 0 !important;
        padding-bottom: 0 !important;
    }
}





/* === Overview section: force left image to match right column height === */
#overview .elementor-element-e44af8c {
    display: flex !important;
    flex-direction: column !important;
    height: 100% !important;
    align-self: stretch !important;
}

#overview .elementor-element-e44af8c .elementor-widget-image {
    display: flex !important;
    flex: 1 1 auto !important;
    height: 100% !important;
    min-height: 0; /* prevents flex overflow bug in Firefox/Safari */
}

#overview .elementor-element-e44af8c .elementor-widget-image .elementor-widget-container {
    display: flex !important;
    width: 100% !important;
    height: 100% !important;
}

#overview .elementor-element-e44af8c .elementor-widget-image img {
    width: 100% !important;
    height: 100% !important;
    max-height: none !important;
    aspect-ratio: unset !important;
    object-fit: cover !important;
    object-position: center !important;
    flex: 1 1 auto !important;
}

/* Make sure the row itself stretches children, not just top-aligns them */
#overview.location-section > .e-con-inner {
    align-items: stretch !important;
}



/* FIX: Project card featured image shrinking after Post URL link was added */
.elementor-1012 .elementor-element.elementor-element-c598482 > .elementor-widget-container > a {
    display: block !important;
    width: 100% !important;
    max-width: 100% !important;
}

.elementor-1012 .elementor-element.elementor-element-c598482 > .elementor-widget-container > a img {
    width: 100% !important;
    max-width: 100% !important;
    height: 370px !important;
    object-fit: cover !important;
    object-position: center center !important;
    border-radius: 24px !important;
    display: block !important;
}

@media (max-width: 1024px) {
    .elementor-1012 .elementor-element.elementor-element-c598482 > .elementor-widget-container > a img {
        height: 280px !important;
    }
}

@media (max-width: 767px) {
    .elementor-1012 .elementor-element.elementor-element-c598482 > .elementor-widget-container > a img {
        height: 240px !important;
    }
}
