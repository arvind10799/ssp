    <script>
    document.addEventListener('DOMContentLoaded', function() {
        /* Remove overflow:hidden from html and body set by Astra/WP Rocket */
        document.documentElement.style.cssText += '; overflow-x: hidden !important; overflow-y: auto !important;';
        document.body.style.cssText += '; overflow-x: hidden !important; overflow-y: auto !important;';
        
        /* Also watch for any late changes and revert them */
        var observer = new MutationObserver(function() {
            var htmlOv = getComputedStyle(document.documentElement).overflowY;
            var bodyOv = getComputedStyle(document.body).overflowY;
            if(htmlOv === 'hidden') {
                document.documentElement.style.cssText += '; overflow-y: auto !important;';
            }
            if(bodyOv === 'hidden') {
                document.body.style.cssText += '; overflow-y: auto !important;';
            }
        });
        
        observer.observe(document.body, { 
            attributes: true, 
            attributeFilter: ['style'],
            subtree: false 
        });
        observer.observe(document.documentElement, { 
            attributes: true, 
            attributeFilter: ['style'],
            subtree: false 
        });
    });
    </script>
