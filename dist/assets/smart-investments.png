.elementor-element-351368 .elementor-item { position: relative; z-index: 1; overflow: hidden; transition: color 0.4s ease !important; }
.elementor-element-351368 .elementor-item::before { content: ""; position: absolute; left: 0; bottom: 0; width: 100%; height: 0%; background: #ff6b00; z-index: -1; transition: height 0.4s ease; border-radius: 4px; }
.elementor-element-351368 .elementor-item:hover::before { height: 100%; }
.elementor-element-351368 .elementor-item:hover { color: #fff !important; transform: none !important; }
.elementor-element-351368.e--animation-grow .elementor-item:hover,
.elementor-element-351368 .e--animation-grow .elementor-item:hover { transform: none !important; }

/* LOCATION SECTION */
.location-section{
    position: relative;
    overflow: hidden;
    padding-top: 140px;
    padding-bottom: 0px;
}
.location-section > .e-con-inner{
    position: relative !important;
    clip-path: inset(-500px 0px -500px 0px);
}
.location-section .bg-location-text{
    position: absolute !important;
    top: -55px;
    left: 0;
    right: 0;
    z-index: 0 !important;
    width: 100% !important;
    max-width: 100% !important;
    overflow: visible;
    pointer-events: none;
    display: flex !important;
}
.location-section .bg-location-text .elementor-widget-container{
    width: 100% !important;
    max-width: 100% !important;
    overflow: visible;
}
.location-section .bg-location-text .elementor-heading-title{
    display: block !important;
    width: 100% !important;
    font-family: "Stack Sans", sans-serif !important;
    line-height: 0.82 !important;
    font-weight: 300 !important;
    margin: 0 !important;
    white-space: nowrap;
    letter-spacing: 0.01em;
    text-align: left;
    transform: scaleX(0.96);
    transform-origin: left center;
    color: transparent !important;
    -webkit-text-stroke: 1px #d2d2d2;
    opacity: 0.8;
}
.location-section .location-row{
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 50px;
}
.location-section .location-row > div:first-child{ width: 55%; }
.location-section .location-row > div:last-child{ width: 45%; }
.location-section .location-row img{ width: 100%; display: block; border-radius: 14px; }

@media(max-width:767px){
    .location-section{ padding-top: 80px; padding-bottom: 40px; }
    .location-section .location-row{ flex-direction: column; gap: 30px; }
    .location-section .location-row > div:first-child,
    .location-section .location-row > div:last-child{ width: 100%; }
    .location-section .bg-location-text{ top: 10px; }
    .location-section .bg-location-text .elementor-heading-title{
        letter-spacing: -4px;
        line-height: 1 !important;
        transform: scaleX(1);
    }
}

/* Route Map Lightbox */
.custom-lightbox{
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 99999;
    padding: 20px;
}
.custom-lightbox img{ max-width: 90%; max-height: 90%; border-radius: 10px; }
.custom-lightbox-close{
    position: absolute;
    top: 20px;
    right: 30px;
    color: #fff;
    font-size: 45px;
    font-weight: bold;
    cursor: pointer;
    z-index: 100000;
    line-height: 1;
    transition: 0.3s;
}
.custom-lightbox-close:hover{ opacity: 0.7; }

@media (min-width: 768px) {
    .route-map-section{
        min-height: 650px !important;
        background-size: cover !important;
        background-repeat: no-repeat !important;
    }
}

/* =============================================
   OVERFLOW FIX — replaces overflow-x: clip
   clip kills position:sticky on all children
============================================= */



/* ===== STICKY HEADER STYLES ===== */
.elementor-sticky--effects {
    background-color: #79481F !important;
    backdrop-filter: blur(10px) !important;
    -webkit-backdrop-filter: blur(10px) !important;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.12) !important;
    min-height: 70px !important;
    transition: all 0.3s ease !important;
}
.elementor-sticky--effects > .elementor-container {
    min-height: 70px !important;
    align-items: center !important;
}
.elementor-sticky--effects .elementor-nav-menu a {
    color: #FFFFFF !important;
    transition: all 0.3s ease !important;
}
/*.elementor-sticky--effects .elementor-nav-menu a:hover,
.elementor-sticky--effects .elementor-nav-menu .current-menu-item a,
.elementor-sticky--effects .elementor-nav-menu .current-menu-ancestor a {
    color: #FFD6A3 !important;
} */
.elementor-sticky--effects .sub-menu {
    background-color: #8A5426 !important;
    border-radius: 10px !important;
    overflow: hidden;
}
.elementor-sticky--effects .sub-menu a { color: #FFFFFF !important; }
.elementor-sticky--effects .sub-menu a:hover {
    background-color: rgba(255,255,255,0.08) !important;
    color: #FFD6A3 !important;
}
/*.elementor-sticky--effects .elementor-button {
    background-color: #FFFFFF !important;
    color: #79481F !important;
    border: 1px solid #FFFFFF !important;
    transition: all 0.3s ease !important;
} 
.elementor-sticky--effects .elementor-button:hover {
    background-color: #FFD6A3 !important;
    color: #79481F !important;
    border-color: #FFD6A3 !important;
} */
.elementor-sticky--effects .elementor-icon,
.elementor-sticky--effects .elementor-icon i,
.elementor-sticky--effects .elementor-menu-toggle {
    color: #FFFFFF !important;
}
.elementor-sticky--effects .elementor-menu-toggle:hover { color: #FFD6A3 !important; }
.elementor-sticky--effects img { transition: all 0.3s ease !important; }


/* Remove all link styles from loop cards */
.ue-carousel-item a,
.ue-carousel-item a:hover,
.ue-carousel-item a:focus,
.ue-carousel-item a:active{
    text-decoration: none !important;
    border: none !important;
    box-shadow: none !important;
    color: inherit !important;
}
.ue-carousel-item .elementor-heading-title{ text-decoration: none !important; }
.ue-carousel-item p{ text-decoration: none !important; }


/* SSP MARQUEE STRIP */
.ssp-marquee-strip {
    width: 100%;
    background-color: #1B4580;
    overflow: hidden;
    height: 49px;
    min-height: 49px;
    display: flex;
    align-items: center;
    position: relative;
    z-index: 3;
}
.ssp-marquee-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: ssp-marquee-scroll 30s linear infinite;
}
.ssp-marquee-strip:hover .ssp-marquee-track { animation-play-state: paused; }
.ssp-marquee-inner {
    display: flex;
    align-items: center;
    white-space: nowrap;
    flex-shrink: 0;
}
@keyframes ssp-marquee-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}
.ssp-marquee-item {
    font-family: "Stack Sans", sans-serif;
    font-size: 28px;
    font-weight: 400;
    color: #ffffff;
    letter-spacing: 0.02em;
    padding: 0 28px;
    line-height: 1;
    white-space: nowrap;
    -webkit-font-smoothing: antialiased;
}
.ssp-marquee-delim { display: inline-flex; align-items: center; flex-shrink: 0; }
.ssp-marquee-star {
    width: 19px;
    height: 21px;
    fill: #F1ECE6;
    flex-shrink: 0;
    vertical-align: middle;
    animation: ssp-star-spin 8s linear infinite;
    transform-origin: center center;
}
@keyframes ssp-star-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
}
@media (max-width: 767px) {
    .ssp-marquee-strip { height: 42px; min-height: 42px; }
    .ssp-marquee-item { font-size: 13px; padding: 0 18px; }
    .ssp-marquee-track { animation-duration: 18s; }
}


