<script>
(function(){
  // Parent section that contains the three containers
  var section = document.querySelector('.elementor-element-e9cac6f');
  if (!section) return;

  // All items that have the data-dce-background-image-url attribute
  var items = section.querySelectorAll('[data-dce-background-image-url]');
  if (!items || items.length === 0) return;

  // Create the background wrapper div
  var bg = document.createElement('div');
  bg.className = 'custom-bg-wrapper';
  section.insertBefore(bg, section.firstChild);

  var currentUrl = '';

  function setBackground(url){
    if (!url) return;
    if (url === currentUrl) return;
    currentUrl = url;
    bg.style.backgroundImage = 'url("' + url + '")';
  }

  // Default background = first (Villas) image
  var defaultUrl = items[0].getAttribute('data-dce-background-image-url') || '';
  setBackground(defaultUrl);

  // Mark first item active
  items.forEach(function(i){ i.classList.remove('active'); });
  if (items[0]) items[0].classList.add('active');

  // Hover + click behavior
  items.forEach(function(item){
    item.style.cursor = 'pointer';

    item.addEventListener('mouseenter', function(){
      var url = item.getAttribute('data-dce-background-image-url');
      setBackground(url);

      items.forEach(function(i){ i.classList.remove('active'); });
      item.classList.add('active');
    });

    // For mobile/touch users – tap to select
    item.addEventListener('click', function(){
      var url = item.getAttribute('data-dce-background-image-url');
      setBackground(url);

      items.forEach(function(i){ i.classList.remove('active'); });
      item.classList.add('active');
    });
  });

  // When leaving the whole section, revert to default (Villas)
  section.addEventListener('mouseleave', function(){
    setBackground(defaultUrl);
    items.forEach(function(i){ i.classList.remove('active'); });
    if (items[0]) items[0].classList.add('active');
  });
})();
</script>

<script>window.lazyLoadOptions=[{elements_selector:"img[data-lazy-src],.rocket-lazyload,iframe[data-lazy-src]",data_src:"lazy-src",data_srcset:"lazy-srcset",data_sizes:"lazy-sizes",class_loading:"lazyloading",class_loaded:"lazyloaded",threshold:300,callback_loaded:function(element){if(element.tagName==="IFRAME"&&element.dataset.rocketLazyload=="fitvidscompatible"){if(element.classList.contains("lazyloaded")){if(typeof window.jQuery!="undefined"){if(jQuery.fn.fitVids){jQuery(element).parent().fitVids()}}}}}},{elements_selector:".rocket-lazyload",data_src:"lazy-src",data_srcset:"lazy-srcset",data_sizes:"lazy-sizes",class_loading:"lazyloading",class_loaded:"lazyloaded",threshold:300,}];window.addEventListener('LazyLoad::Initialized',function(e){var lazyLoadInstance=e.detail.instance;if(window.MutationObserver){var observer=new MutationObserver(function(mutations){var image_count=0;var iframe_count=0;var rocketlazy_count=0;mutations.forEach(function(mutation){for(var i=0;i<mutation.addedNodes.length;i++){if(typeof mutation.addedNodes[i].getElementsByTagName!=='function'){continue}
