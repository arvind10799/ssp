.map-container,
.map-container * {
    font-family: 'Manrope', sans-serif !important;
}

@font-face {
  font-family: 'Semplicita';
  src: url('https://ec2e6e6c.delivery.rocketcdn.me/wp-content/uploads/2024/10/Semplicita-Medium.woff') format('woff');
  font-display: swap;
}

@font-face {
