<script id="dream-lifestyle-js-js-after">
function initDreamSection() {

        document.documentElement.style.cssText += '; overflow-x:hidden !important; overflow-y:auto !important;';
        document.body.style.cssText += '; overflow-x:hidden !important; overflow-y:auto !important;';

        var section = document.querySelector('[data-id="cf90ae3"]');

        if (!section) { console.log('Dream section: not found'); return; }
        console.log('Dream section: scroll-stack mode');

        var vh = window.innerHeight;
        var cardHeight = 280;
        var cardGap = 20;
        var totalCards = 4;

        /* Fix all parents overflow */
        var el = section.parentElement;
        while(el && el !== document.body) {
            el.style.cssText += '; overflow:visible !important;';
            el = el.parentElement;
        }

        /* Force section height — enough scroll room for all cards */
        section.style.cssText =
            'position:relative !important;' +
            'overflow:visible !important;' +
            'min-height:' + (vh * 5) + 'px !important;' +
            'height:' + (vh * 5) + 'px !important;' +
            'padding:0 !important;' +
            'display:block !important;';

        /* Hide original sticky inner and spacers */
        var stickyInner = document.querySelector('[data-id="c801edf"]');
        if(stickyInner) stickyInner.style.cssText = 'display:none !important;';

        var spacerIds = ['bfd8440','4381a39','1dc012d','b2d3372'];
        spacerIds.forEach(function(id) {
            var el = document.querySelector('[data-id="' + id + '"]');
            if(el) el.style.cssText = 'display:none !important;';
        });

        /* Card data */
        var cards = [
            {
                side: 'right',
                icon: '<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 54 54" fill="none"><rect x="1" y="1" width="52" height="52" rx="12" stroke="#C4826A" stroke-width="1.5"/><path d="M17 38V28M17 28C17 23 20 20 27 20C34 20 37 23 37 28M37 38V28M22 38V32H32V38" stroke="#C4826A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>',
                title: 'Private Backyard',
                desc: 'Enjoy your own private backyard — a peaceful retreat for family time, relaxation, and weekend gatherings.'
            },
            {
                side: 'left',
                icon: '<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 54 54" fill="none"><rect x="1" y="1" width="52" height="52" rx="12" stroke="#C4826A" stroke-width="1.5"/><path d="M14 38H40M16 38V26L27 18L38 26V38M22 38V32H32V38" stroke="#C4826A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="27" cy="24" r="2" stroke="#C4826A" stroke-width="1.5"/></svg>',
                title: 'Grand Clubhouse',
                desc: 'A world-class clubhouse with premium amenities — your social hub for celebrations and community living.'
            },
            {
                side: 'right',
                icon: '<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 54 54" fill="none"><rect x="1" y="1" width="52" height="52" rx="12" stroke="#C4826A" stroke-width="1.5"/><path d="M14 30C17 30 17 33 20 33C23 33 23 30 26 30C29 30 29 33 32 33C35 33 35 30 38 30M14 35C17 35 17 38 20 38C23 38 23 35 26 35C29 35 29 38 32 38C35 38 35 35 38 35" stroke="#C4826A" stroke-width="1.5" stroke-linecap="round"/></svg>',
                title: 'Swimming Pool',
                desc: 'Dive into luxury with a beautifully designed swimming pool — perfect for morning laps and evening dips.'
            },
            {
                side: 'left',
                icon: '<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 54 54" fill="none"><rect x="1" y="1" width="52" height="52" rx="12" stroke="#C4826A" stroke-width="1.5"/><path d="M27 38V28M27 28C27 28 20 26 18 20C22 19 26 22 27 28M27 28C27 28 34 26 36 20C32 19 28 22 27 28" stroke="#C4826A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M20 38H34" stroke="#C4826A" stroke-width="1.5" stroke-linecap="round"/></svg>',
                title: '60% Green Open Space',
                desc: 'Breathe fresh air in lush green landscapes — 60% of the community dedicated to open spaces and nature.'
            }
        ];

        /* Create fixed overlay */
        var overlay = document.createElement('div');
        overlay.id = 'dream-overlay';
        overlay.style.cssText =
            'position:fixed !important;' +
            'top:0 !important;' +
            'left:0 !important;' +
            'width:100% !important;' +
            'height:100vh !important;' +
            'z-index:100 !important;' +
            'pointer-events:none !important;' +
            'opacity:0 !important;' +
            'transition:opacity 0.3s ease !important;' +
            'overflow:hidden !important;' +
            'background: #F5EDE6 !important;';

        /* Marquee inside overlay */
        var marquee = document.createElement('div');
        marquee.style.cssText =
            'position:absolute !important;' +
            'bottom:40px !important;' +
            'left:0 !important;' +
            'width:100% !important;' +
            'overflow:hidden !important;' +
            'white-space:nowrap !important;' +
            'z-index:1 !important;';
        marquee.innerHTML = '<div style="display:inline-block;animation:dlMarquee 18s linear infinite;font-size:clamp(60px,10vw,150px);font-weight:700;color:#C4826A;line-height:1;padding-right:100px;font-family:serif;">Live Your Dream Lifestyle &nbsp;&nbsp;&nbsp; Live Your Dream Lifestyle &nbsp;&nbsp;&nbsp;</div>';
        overlay.appendChild(marquee);

        /* Cards container inside overlay */
        var cardsContainer = document.createElement('div');
        cardsContainer.style.cssText =
            'position:absolute !important;' +
            'top:0 !important;' +
            'left:0 !important;' +
            'width:100% !important;' +
            'height:100% !important;' +
            'pointer-events:none !important;' +
            'z-index:2 !important;';
        overlay.appendChild(cardsContainer);

        /* Create card elements */
        var cardEls = [];
        cards.forEach(function(card, i) {
            var div = document.createElement('div');
            var isRight = card.side === 'right';
            div.style.cssText =
                'position:absolute !important;' +
                'width:380px !important;' +
                'background:#FDF6F0 !important;' +
                'border-radius:16px !important;' +
                'padding:28px !important;' +
                'box-sizing:border-box !important;' +
                'box-shadow:0 4px 30px rgba(0,0,0,0.08) !important;' +
                (isRight ? 'right:60px !important;' : 'left:60px !important;') +
                'bottom:-320px !important;' +
                'transition:bottom 0.6s cubic-bezier(0.25,0.46,0.45,0.94) !important;' +
                'pointer-events:auto !important;';

            div.innerHTML =
                '<div style="margin-bottom:14px">' + card.icon + '</div>' +
                '<div style="font-family:Manrope,sans-serif;font-size:18px;font-weight:600;color:#1a1a2e;margin-bottom:12px">' + card.title + '</div>' +
                '<div style="width:100%;height:1px;background:#e8d5c8;margin-bottom:12px"></div>' +
                '<div style="font-family:Manrope,sans-serif;font-size:14px;color:#666;line-height:1.7">' + card.desc + '</div>';

            cardsContainer.appendChild(div);
            cardEls.push(div);
        });

        document.body.appendChild(overlay);

        /* Add marquee keyframe */
        var style = document.createElement('style');
        style.innerHTML = '@keyframes dlMarquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }';
        document.head.appendChild(style);

        /* Scroll handler */
        window.addEventListener('scroll', function() {
            var rect = section.getBoundingClientRect();
            var sectionTop = rect.top;
            var sectionBottom = rect.bottom;
            var isInSection = sectionTop <= 0 && sectionBottom > vh;

            /* Show/hide overlay */
            overlay.style.opacity = isInSection ? '1' : '0';
            overlay.style.pointerEvents = isInSection ? 'none' : 'none';

            if(!isInSection) return;

            var scrolled = -sectionTop;
            var totalScroll = section.offsetHeight - vh;
            var progress = Math.max(0, Math.min(1, scrolled / totalScroll));

            /* Each card gets 25% of scroll progress */
            cardEls.forEach(function(el, i) {
                var cardProgress = (progress - i * 0.22) / 0.22;
                cardProgress = Math.max(0, Math.min(1, cardProgress));

                /* Card slides up from bottom */
                var targetBottom = 60 + i * (cardHeight + cardGap);
                var startBottom = -320;
                var currentBottom = startBottom + (targetBottom - startBottom) * cardProgress;

                el.style.bottom = currentBottom + 'px';
            });
        });

        console.log('Dream section: scroll-stack initialized');
    }

    window.addEventListener('load', function() {
        setTimeout(initDreamSection, 800);
    });
    
//# sourceURL=dream-lifestyle-js-js-after
</script>
